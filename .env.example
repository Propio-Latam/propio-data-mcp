# Server
HOST=0.0.0.0
PORT=8000

# Auth — comma-separated API keys
API_KEYS=change-me-to-a-real-key

# Internal SQLite registry (stores database configs)
REGISTRY_PATH=./data/registry.db

# Optional: encryption key for stored connection strings (Fernet key)
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# ENCRYPTION_KEY=
